<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Collection Settings -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Collection"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.CardView.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Collection Interval"
                    android:textSize="14sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="Collection interval in seconds"
                    android:valueFrom="1"
                    android:valueTo="30"
                    android:stepSize="1"
                    android:value="5" />

                <TextView
                    android:id="@+id/text_interval_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5 seconds"
                    android:textSize="12sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Auto-delete data older than"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_retention"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="Data retention period in days"
                    android:valueFrom="0"
                    android:valueTo="365"
                    android:stepSize="1"
                    android:value="0" />

                <TextView
                    android:id="@+id/text_retention_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    android:textSize="12sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Export -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Export Data"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.CardView.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_export"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:max="100"
                    android:visibility="gone"
                    app:trackThickness="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export_csv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Export as CSV"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export_geojson"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Export as GeoJSON"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export_kml"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Export as KML"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Statistics"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.CardView.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_total_measurements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Measurements: 0"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/text_total_sessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Sessions: 0"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/text_tower_cache"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cached Towers: 0"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- About -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.CardView.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cell Tower ID v1.0.0"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cell tower mapper, signal tracker, and IMSI catcher detector.\n\nAll monitoring is passive and defensive. All data stays on your device."
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_licenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Open source licences"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_debug_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View debug log"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_privacy_policy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_policy"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
