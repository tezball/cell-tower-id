<?xml version="1.0" encoding="utf-8"?>
<!--
  Used on Android 11 and below (allowBackup="true" in the manifest).
  Backup is scoped to SharedPreferences only: the Room database (cell
  measurements, anomalies, sessions, pinned-tower cache), persistent logs,
  crash dumps, and exported files are all excluded so no precise location
  data ever transits Google Drive. Phone-switch users keep their settings
  (theme, retention, scan interval); they re-collect their tower history.
-->
<full-backup-content>
    <exclude domain="database" path="cellid_database" />
    <exclude domain="database" path="cellid_database-shm" />
    <exclude domain="database" path="cellid_database-wal" />
    <exclude domain="file" path="logs/" />
    <exclude domain="file" path="crashes/" />
    <exclude domain="external" path="logs/" />
    <exclude domain="external" path="crashes/" />
    <exclude domain="external" path="exports/" />
</full-backup-content>
