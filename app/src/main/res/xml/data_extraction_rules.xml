<?xml version="1.0" encoding="utf-8"?>
<!--
  allowBackup is false in the manifest so cloud-backup is disabled, but
  keep explicit database excludes for defence-in-depth. The Room DB
  contains precise location tracks and must never transit Google Drive
  or D2D transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="cellid_database" />
        <exclude domain="database" path="cellid_database-shm" />
        <exclude domain="database" path="cellid_database-wal" />
        <exclude domain="file" path="logs/" />
        <exclude domain="file" path="crashes/" />
        <exclude domain="external" path="logs/" />
        <exclude domain="external" path="crashes/" />
        <exclude domain="external" path="exports/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="cellid_database" />
        <exclude domain="database" path="cellid_database-shm" />
        <exclude domain="database" path="cellid_database-wal" />
        <exclude domain="file" path="logs/" />
        <exclude domain="file" path="crashes/" />
    </device-transfer>
</data-extraction-rules>
